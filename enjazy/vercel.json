{
  "headers": [
    {
      "source": "/auth.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/auth",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/admin-v2.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/admin",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/auth",
      "destination": "/auth.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin-v2",
      "destination": "/admin-v2.html"
    },
    {
      "source": "/share/:id",
      "destination": "/index.html"
    }
  ]
}
