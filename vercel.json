{
  "version": 2,
  "headers": [
    {
      "source": "/enjazy/auth.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/enjazy/auth",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/enjazy/admin.html",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/enjazy/admin",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=UTF-8" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/enjazy/api/:path*", "destination": "/api/:path*" },
    { "source": "/share/:id", "destination": "/enjazy/index.html" },
    { "source": "/enjazy/share/:id", "destination": "/enjazy/index.html" },
    { "source": "/enjazy/auth", "destination": "/enjazy/auth.html" },
    { "source": "/enjazy/admin", "destination": "/enjazy/admin.html" },
    { "source": "/t", "destination": "/t.html" },
    { "source": "/m", "destination": "/m.html" },
    { "source": "/enjazy", "destination": "/enjazy/index.html" },
    { "source": "/enjazy/:path*", "destination": "/enjazy/:path*" },
    { "source": "/", "destination": "/index.html" }
  ]
}
